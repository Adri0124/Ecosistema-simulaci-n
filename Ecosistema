
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Infografía Integral: Simulación de un Ecosistema</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background-color: #f8fafc;
            color: #1e293b;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            scroll-behavior: smooth;
        }
        .chart-container {
            position: relative;
            width: 100%;
            height: 300px;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s ease;
        }
        .scenario-btn.active {
            border-color: #0D6EFD;
            background-color: #eff6ff;
            transform: scale(1.02);
            box-shadow: 0 10px 15px -3px rgba(13, 110, 253, 0.1);
        }
        input[type="range"] {
            accent-color: #20C997;
        }
        #energySlider {
            accent-color: #FFC107;
        }
        .download-btn {
            transition: all 0.2s;
        }
        .download-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }
        .status-badge {
            transition: all 0.5s ease;
        }
    </style>
</head>
<body class="antialiased">

    <nav class="sticky top-0 z-50 bg-white shadow-md border-b-4 border-[#20C997]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <span class="text-xl font-bold text-slate-800">🌱 AgroEcosistemas Lab</span>
                </div>
                <div class="flex items-center gap-4">
                    <button id="downloadFile" class="download-btn text-sm font-bold text-white bg-[#0D6EFD] px-4 py-2 rounded-lg flex items-center gap-2">
                        <span>📥 Descargar Archivo</span>
                    </button>
                    <span class="hidden md:inline text-sm font-semibold text-[#0D6EFD] bg-blue-50 px-3 py-1 rounded-full">Ingeniería Agronómica</span>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <header class="text-center mb-16 mt-8">
            <h1 class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-[#FF3366] to-[#6F42C1] mb-4">Simulación de un Ecosistema</h1>
            <p class="text-xl text-slate-600 max-w-3xl mx-auto">Experiencia interactiva sobre el flujo de energía biótica, eficiencia ecológica y equilibrio poblacional.</p>
        </header>

        <!-- SECCIÓN 1: Contexto y Cadena -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
            <section class="bg-white rounded-2xl shadow-xl p-8 border-t-8 border-[#FFC107]">
                <h2 class="text-2xl font-bold mb-6 text-slate-800">Contexto del Taller</h2>
                <div class="grid grid-cols-3 gap-4 text-center">
                    <div class="p-4 bg-amber-50 rounded-xl">
                        <div class="text-4xl font-black text-[#FFC107]">150</div>
                        <div class="text-[10px] font-bold text-slate-500 uppercase">Estudiantes</div>
                    </div>
                    <div class="p-4 bg-emerald-50 rounded-xl">
                        <div class="text-4xl font-black text-[#20C997]">25</div>
                        <div class="text-[10px] font-bold text-slate-500 uppercase">Grupos</div>
                    </div>
                    <div class="p-4 bg-blue-50 rounded-xl">
                        <div class="text-4xl font-black text-[#0D6EFD]">90</div>
                        <div class="text-[10px] font-bold text-slate-500 uppercase">Minutos</div>
                    </div>
                </div>
            </section>

            <section class="bg-white rounded-2xl shadow-xl p-8 border-t-8 border-[#6F42C1]">
                <h2 class="text-2xl font-bold mb-6 text-slate-800">Estructura Trófica</h2>
                <div class="flex items-center justify-around">
                    <div class="text-center">
                        <span class="text-3xl block">🌱</span>
                        <span class="text-[10px] font-bold">1% Sol</span>
                    </div>
                    <span class="text-slate-300">→</span>
                    <div class="text-center">
                        <span class="text-3xl block">🐛</span>
                        <span class="text-[10px] font-bold">10% T1</span>
                    </div>
                    <span class="text-slate-300">→</span>
                    <div class="text-center">
                        <span class="text-3xl block">🦅</span>
                        <span class="text-[10px] font-bold">10% T2</span>
                    </div>
                </div>
            </section>
        </div>

        <!-- SECCIÓN 2: Simulador de Energía -->
        <section class="mb-16">
            <div class="bg-slate-800 rounded-3xl shadow-2xl p-8 text-white relative overflow-hidden">
                <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                    <div>
                        <div class="inline-block px-3 py-1 bg-amber-500/20 text-amber-400 text-xs font-bold uppercase tracking-wider rounded-full mb-4">Eficiencia Ecológica</div>
                        <h2 class="text-3xl font-bold mb-4">Energía en la Biomasa</h2>
                        <p class="text-slate-300 mb-6 italic text-sm">Mueve el control de radiación solar para ver cuánta energía logran retener los seres vivos (1% captura, 10% transferencia).</p>
                        
                        <div class="space-y-6 bg-slate-700/50 p-6 rounded-2xl border border-slate-600">
                            <div>
                                <label class="flex justify-between mb-2">
                                    <span class="font-semibold text-sm text-amber-400">Energía Solar Entrante:</span>
                                    <span id="sunValueDisplay" class="text-white font-black text-xl">10.000 u</span>
                                </label>
                                <input type="range" id="energySlider" min="1000" max="50000" value="10000" step="500" class="w-full h-2 bg-slate-600 rounded-lg appearance-none cursor-pointer">
                            </div>
                            
                            <div class="grid grid-cols-3 gap-2 text-[10px]">
                                <div class="p-2 bg-slate-800 rounded-lg border-l-2 border-[#20C997]">
                                    <span class="text-slate-400 block uppercase">Plantas</span>
                                    <span id="prodValue" class="text-[#20C997] font-bold text-sm">100.0</span>
                                </div>
                                <div class="p-2 bg-slate-800 rounded-lg border-l-2 border-[#0D6EFD]">
                                    <span class="text-slate-400 block uppercase">Herbívoros</span>
                                    <span id="primValue" class="text-[#0D6EFD] font-bold text-sm">10.00</span>
                                </div>
                                <div class="p-2 bg-slate-800 rounded-lg border-l-2 border-[#FF3366]">
                                    <span class="text-slate-400 block uppercase">Carnívoros</span>
                                    <span id="secValue" class="text-[#FF3366] font-bold text-sm">1.00</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-inner">
                        <div class="chart-container">
                            <canvas id="energyChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN 3: Simulador de Equilibrio Poblacional -->
        <section class="mb-16">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold text-slate-800 mb-2">Simulador de Capacidad de Carga</h2>
                <p class="text-slate-500">Ajusta las poblaciones y observa el diagnóstico de equilibrio del ecosistema.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
                <!-- Controles -->
                <div class="bg-white p-8 rounded-2xl shadow-xl space-y-8">
                    <div>
                        <label class="flex justify-between text-sm font-bold text-slate-700 mb-2">
                            <span>🌱 Productores (Plantas)</span>
                            <span id="vplantas" class="text-emerald-600">60</span>
                        </label>
                        <input type="range" min="0" max="100" value="60" id="plantas" oninput="calcularEquilibrio()" class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
                    </div>

                    <div>
                        <label class="flex justify-between text-sm font-bold text-slate-700 mb-2">
                            <span>🐛 Cons. Primarios (Herbívoros)</span>
                            <span id="vherbivoros" class="text-blue-600">30</span>
                        </label>
                        <input type="range" min="0" max="100" value="30" id="herbivoros" oninput="calcularEquilibrio()" class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
                    </div>

                    <div>
                        <label class="flex justify-between text-sm font-bold text-slate-700 mb-2">
                            <span>🦅 Cons. Secundarios (Depredadores)</span>
                            <span id="vdepredadores" class="text-red-600">10</span>
                        </label>
                        <input type="range" min="0" max="100" value="10" id="depredadores" oninput="calcularEquilibrio()" class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
                    </div>
                </div>

                <!-- Resultado Diagnóstico -->
                <div class="lg:col-span-2 bg-white p-8 rounded-2xl shadow-xl border-2 border-dashed border-slate-200 flex flex-col justify-center min-h-[300px]">
                    <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
                        <span>🔍 Diagnóstico del Ecosistema:</span>
                    </h3>
                    
                    <div id="resultadoCaja" class="p-6 rounded-xl bg-emerald-50 border-l-8 border-emerald-500 status-badge">
                        <p id="estado" class="text-lg font-medium text-slate-700 leading-relaxed italic">
                            El ecosistema está relativamente equilibrado.
                        </p>
                    </div>

                    <div class="mt-8 grid grid-cols-3 gap-4">
                        <div class="text-center">
                            <div id="barPlantas" class="w-full bg-emerald-500 rounded-t-lg transition-all duration-500" style="height: 60px;"></div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase">Biomasa P.</span>
                        </div>
                        <div class="text-center">
                            <div id="barHerb" class="w-full bg-blue-500 rounded-t-lg transition-all duration-500" style="height: 30px;"></div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase">Biomasa H.</span>
                        </div>
                        <div class="text-center">
                            <div id="barDep" class="w-full bg-red-500 rounded-t-lg transition-all duration-500" style="height: 10px;"></div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase">Biomasa D.</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN 4: Dinámica de Escenarios -->
        <section class="mb-16">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold text-slate-800 mb-2">Dinámica de Disturbios</h2>
                <p class="text-slate-500">Analiza qué sucede ante cambios externos en la biodiversidad.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                <button onclick="updateScenario('normal')" id="btn-normal" class="scenario-btn active glass-card rounded-2xl p-6 text-left border-2 border-transparent">
                    <span class="text-2xl mb-2 block">⚖️</span>
                    <h3 class="font-bold text-slate-800">Equilibrio Natural</h3>
                    <p class="text-xs text-slate-500">Flujo máximo.</p>
                </button>
                <button onclick="updateScenario('quimicos')" id="btn-quimicos" class="scenario-btn glass-card rounded-2xl p-6 text-left border-2 border-transparent">
                    <span class="text-2xl mb-2 block">🧪</span>
                    <h3 class="font-bold text-slate-800">Uso de Químicos</h3>
                    <p class="text-xs text-slate-500">Efecto cascada.</p>
                </button>
                <button onclick="updateScenario('suelo')" id="btn-suelo" class="scenario-btn glass-card rounded-2xl p-6 text-left border-2 border-transparent">
                    <span class="text-2xl mb-2 block">🍂</span>
                    <h3 class="font-bold text-slate-800">Suelo Degradado</h3>
                    <p class="text-xs text-slate-500">Colapso base.</p>
                </button>
            </div>

            <div class="bg-white rounded-3xl shadow-xl overflow-hidden grid grid-cols-1 lg:grid-cols-2">
                <div class="p-10 bg-slate-50">
                    <h3 id="scenarioTitle" class="text-2xl font-bold text-slate-800 mb-4">Estado de Equilibrio</h3>
                    <p id="scenarioDesc" class="text-slate-600 mb-6 leading-relaxed">La fotosíntesis es máxima y la transferencia de energía permite sostener a los carnívoros superiores sin problema.</p>
                    
                    <div class="p-4 bg-white rounded-xl shadow-sm border-l-4 border-[#20C997] flex items-center">
                        <div id="statusIcon" class="text-2xl mr-4">✅</div>
                        <div>
                            <h4 class="font-bold text-sm text-slate-800">Resiliencia</h4>
                            <p id="statusText" class="text-xs text-slate-500">Alta eficiencia termodinámica.</p>
                        </div>
                    </div>
                </div>
                <div class="p-10 flex items-center justify-center bg-white">
                    <div class="chart-container" style="height: 350px;">
                        <canvas id="scenarioChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- Conclusión -->
        <section class="bg-[#0D6EFD] rounded-2xl shadow-xl p-10 text-white text-center">
            <h2 class="text-3xl font-bold mb-6">Lección Agronómica</h2>
            <p class="text-lg text-blue-100 max-w-4xl mx-auto mb-8 leading-relaxed">
                El diseño de agroecosistemas depende de entender que la captura solar es solo del <strong class="text-white">1%</strong>. Mantener el equilibrio poblacional evita el uso de insumos químicos, permitiendo que la propia biodiversidad regule el sistema.
            </p>
            <div class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-bold rounded-full text-[#0D6EFD] bg-white shadow-lg">
                Agroecología Aplicada
            </div>
        </section>

    </main>

    <footer class="bg-slate-100 border-t border-slate-200 py-10 text-center">
        <p class="text-sm text-slate-400 font-bold mb-2 uppercase tracking-widest">Simulador Integral v5.0 - Ingeniería Agronómica</p>
    </footer>

    <script>
        // --- FUNCIONALIDAD DE DESCARGA ---
        document.getElementById('downloadFile').addEventListener('click', function() {
            const htmlContent = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
            const blob = new Blob([htmlContent], { type: 'text/html' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'ecosistema_simulador_integral.html';
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        });

        // --- LÓGICA DE EQUILIBRIO POBLACIONAL ---
        function calcularEquilibrio() {
            let p = parseInt(document.getElementById("plantas").value);
            let h = parseInt(document.getElementById("herbivoros").value);
            let d = parseInt(document.getElementById("depredadores").value);

            document.getElementById("vplantas").innerText = p;
            document.getElementById("vherbivoros").innerText = h;
            document.getElementById("vdepredadores").innerText = d;

            document.getElementById("barPlantas").style.height = (p * 1.5) + "px";
            document.getElementById("barHerb").style.height = (h * 1.5) + "px";
            document.getElementById("barDep").style.height = (d * 1.5) + "px";

            let estado = "";
            let colorClase = "";
            let bordeClase = "";

            if (p > h && h > d) {
                estado = "El ecosistema está relativamente equilibrado.";
                colorClase = "bg-emerald-50";
                bordeClase = "border-emerald-500";
            } else if (h > p) {
                estado = "⚠️ Demasiados herbívoros: las plantas pueden disminuir drásticamente (Sobrepastoreo).";
                colorClase = "bg-amber-50";
                bordeClase = "border-amber-500";
            } else if (d > h) {
                estado = "⚠️ Muchos depredadores: la población de herbívoros podría colapsar, dejando sin alimento a los carnívoros.";
                colorClase = "bg-red-50";
                bordeClase = "border-red-500";
            } else if (p < 20) {
                estado = "🚨 Poca vegetación: base productiva insuficiente. El ecosistema puede colapsar.";
                colorClase = "bg-slate-200";
                bordeClase = "border-slate-800";
            } else {
                estado = "El sistema presenta desequilibrios en la cadena de transferencia.";
                colorClase = "bg-blue-50";
                bordeClase = "border-blue-400";
            }

            const caja = document.getElementById("resultadoCaja");
            caja.className = `p-6 rounded-xl ${colorClase} border-l-8 ${bordeClase} status-badge`;
            document.getElementById("estado").innerText = estado;
        }

        // --- LÓGICA DEL SIMULADOR DE ENERGÍA ---
        const energySlider = document.getElementById('energySlider');
        const sunValueDisplay = document.getElementById('sunValueDisplay');
        const prodValue = document.getElementById('prodValue');
        const primValue = document.getElementById('primValue');
        const secValue = document.getElementById('secValue');
        
        let energyChart;
        const energyCtx = document.getElementById('energyChart').getContext('2d');

        function initEnergyChart() {
            energyChart = new Chart(energyCtx, {
                type: 'bar',
                data: {
                    labels: ['🌱 Plantas', '🐛 Herbívoros', '🦅 Carnívoros'],
                    datasets: [{
                        label: 'Energía Retenida',
                        data: [100, 10, 1],
                        backgroundColor: ['#20C997', '#0D6EFD', '#FF3366'],
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { color: '#94a3b8' } },
                        x: { ticks: { color: '#64748b', font: { weight: 'bold' } } }
                    }
                }
            });
        }

        energySlider.addEventListener('input', (e) => {
            const sunVal = parseInt(e.target.value);
            const plantVal = sunVal * 0.01;
            const herbVal = plantVal * 0.1;
            const carnVal = herbVal * 0.1;

            sunValueDisplay.innerText = `${sunVal.toLocaleString()} u`;
            prodValue.innerText = plantVal.toFixed(1);
            primValue.innerText = herbVal.toFixed(2);
            secValue.innerText = carnVal.toFixed(2);

            energyChart.data.datasets[0].data = [plantVal, herbVal, carnVal];
            energyChart.update('none'); 
        });

        // --- LÓGICA DE ESCENARIOS ---
        let scenarioChart;
        const scenarioCtx = document.getElementById('scenarioChart').getContext('2d');

        const scenarios = {
            normal: {
                title: "Estado de Equilibrio",
                desc: "La transferencia energética es fluida. El 1% inicial se aprovecha al máximo para sostener toda la cadena trófica.",
                status: "Alta eficiencia termodinámica.",
                icon: "✅",
                data: [20, 20, 20, 20, 20]
            },
            quimicos: {
                title: "Impacto por Agroquímicos",
                desc: "Los carnívoros mueren por bioacumulación. La energía se 'atasca' en los herbívoros, que se convierten en plagas.",
                status: "Desbalance poblacional severo.",
                icon: "🧪",
                data: [35, 50, 2, 8, 5]
            },
            suelo: {
                title: "Suelo Degradado",
                desc: "Sin nutrientes, las plantas no capturan energía. Toda la pirámide se encoge drásticamente.",
                status: "Baja productividad primaria.",
                icon: "🍂",
                data: [10, 10, 10, 60, 10]
            }
        };

        function updateScenario(type) {
            const s = scenarios[type];
            document.getElementById('scenarioTitle').innerText = s.title;
            document.getElementById('scenarioDesc').innerText = s.desc;
            document.getElementById('statusText').innerText = s.status;
            document.getElementById('statusIcon').innerText = s.icon;
            document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-${type}`).classList.add('active');
            scenarioChart.data.datasets[0].data = s.data;
            scenarioChart.update();
        }

        function initScenarioChart() {
            scenarioChart = new Chart(scenarioCtx, {
                type: 'polarArea',
                data: {
                    labels: ['Plantas', 'Herbívoros', 'Carnívoros', 'Suelo', 'Descomponedores'],
                    datasets: [{
                        data: scenarios.normal.data,
                        backgroundColor: ['rgba(32, 201, 151, 0.7)', 'rgba(13, 110, 253, 0.7)', 'rgba(255, 51, 102, 0.7)', 'rgba(255, 193, 7, 0.7)', 'rgba(111, 66, 193, 0.7)']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { r: { ticks: { display: false } } } }
            });
        }

        window.onload = () => {
            initEnergyChart();
            initScenarioChart();
            calcularEquilibrio();
        };
    </script>
</body>
</html>
